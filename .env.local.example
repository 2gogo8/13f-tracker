# === Google OAuth (NextAuth) ===
GOOGLE_CLIENT_ID=          # Google Cloud Console OAuth 2.0 Client ID
GOOGLE_CLIENT_SECRET=      # Google Cloud Console OAuth 2.0 Client Secret

# === NextAuth ===
NEXTAUTH_SECRET=           # 隨機字串，可用 openssl rand -base64 32 生成
NEXTAUTH_URL=https://你的網域

# === YouTube Membership Verification ===
YT_OWNER_REFRESH_TOKEN=    # JG 頻道主的 refresh token（需有 youtube.channel-memberships.creator scope）
YT_CHANNEL_ID=             # JG 的 YouTube 頻道 ID（例如 UCxxxxxxxx）

# === Vercel Cron (optional) ===
CRON_SECRET=               # Vercel Cron 自動設定，用於 /api/sync-members 授權

# === Upstash Redis (already configured) ===
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
