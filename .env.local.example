# === Discord OAuth (NextAuth) ===
DISCORD_CLIENT_ID=         # Discord Developer Portal → Application → OAuth2 → Client ID
DISCORD_CLIENT_SECRET=     # Discord Developer Portal → Application → OAuth2 → Client Secret

# === NextAuth ===
NEXTAUTH_SECRET=           # 隨機字串，可用 openssl rand -base64 32 生成
NEXTAUTH_URL=https://你的網域

# === Vercel Cron (optional) ===
CRON_SECRET=               # Vercel Cron 自動設定，用於 /api/sync-members 授權

# === Upstash Redis (already configured) ===
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
